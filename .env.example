# CitySarthi Environment Variables Example (Safe for GitHub)

# Supabase Credentials
EXPO_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# API & External Services
EXPO_PUBLIC_API_URL=https://api.citysarthi.com/v1
EXPO_PUBLIC_SOCKET_URL=https://socket.citysarthi.com
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
EXPO_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your_key_id
EXPO_PUBLIC_ENV=development
